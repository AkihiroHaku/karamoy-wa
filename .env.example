# ── OpenRouter ──────────────────────────────────────────────
# Dapatkan API key di https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model yang dipakai. Default: openrouter/auto (auto-route ke model terbaik)
# Alternatif hemat: google/gemini-flash-1.5, mistralai/mistral-7b-instruct
OPENROUTER_MODEL=openrouter/auto

# ── AI Access Control ────────────────────────────────────────
# Nomor owner (format internasional tanpa +), pisah koma jika lebih dari satu
# Contoh: 628123456789 atau 628123456789,628987654321
AI_OWNER_NUMBER=

# ── AI Behaviour ─────────────────────────────────────────────
# Jumlah pesan (user+assistant) yang disimpan sebagai konteks
AI_MAX_HISTORY=10

# Maksimal token output dari model
AI_MAX_TOKENS=800

# Kreativitas model: 0.0 (deterministik) – 1.0 (kreatif)
AI_TEMPERATURE=0.7
